# Python
.venv/
__pycache__/
*.pyc

# Downloaded/generated data (EMBER2024 raw + vectorized, tens of GB)
/data/

# LLM report cache (regenerable, costs API calls to rebuild)
checkpoints/llm_cache/

# In-progress family artifacts; deployed files are replaced only after evaluation succeeds.
checkpoints/.family_mlp.training.pt
checkpoints/.family_mlp.training.pt.tmp
checkpoints/.family_labels.training.json
checkpoints/.family_labels.training.json.tmp
checkpoints/.mlp.training.pt
checkpoints/.mlp.training.pt.tmp
checkpoints/.scaler.training.pkl
checkpoints/.scaler.training.pkl.tmp
checkpoints/lightgbm.txt.tmp

# Ablation run logs (the trained models + metrics json are committed; logs are not)
checkpoints/ablation/*.log

# Node
webapp/frontend/node_modules/
webapp/frontend/dist/

# Demo binaries — real detectors may flag suspicious_demo.exe; benign samples are
# real installers (7-Zip, Git, etc.) kept locally for demo but not pushed to the repo.
demo_samples/suspicious_demo.exe
demo_samples/benign_samples/*.exe

# Secrets
.env
*.env.local

# OS/editor cruft
.DS_Store
Thumbs.db
